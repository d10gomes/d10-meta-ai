# App
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
APP_DEBUG=true

# Supabase / PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://redis:6379/0

# Meta (Facebook) API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_API_VERSION=v19.0

# WhatsApp (Evolution API or Meta Cloud API)
WHATSAPP_API_URL=https://your-whatsapp-api.com
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_DEFAULT_NUMBER=5511999999999

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=D10 META AI

# JWT
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Scheduler
SCANNER_INTERVAL_MINUTES=30
DOCTOR_INTERVAL_MINUTES=60
REPORT_CRON=0 8 * * *
